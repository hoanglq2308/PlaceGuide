digraph ERD {
  graph [rankdir=LR, splines=ortho, nodesep=0.55, ranksep=1.1, bgcolor="white"];
  node [shape=record, fontname="Arial", fontsize=10, style="rounded,filled", fillcolor="#F8FBFF", color="#2F4F6F"];
  edge [fontname="Arial", fontsize=9, color="#667085", arrowsize=0.7];
  "roles" [label="{roles|id PK\lcode UK\lname\l}"];
  "users" [label="{users|id PK\lrole_id FK\lfull_name\lemail UK\lstatus\l}"];
  "user_profiles" [label="{user_profiles|user_id PK/FK\lpreferred_language_id FK\lnationality\l}"];
  "languages" [label="{languages|id PK\lcode UK\lname\l}"];
  "currencies" [label="{currencies|id PK\lcode UK\lexchange_to_vnd\l}"];
  "restaurants" [label="{restaurants|id PK\lowner_id FK\lname\llatitude\llongitude\lstatus\l}"];
  "restaurant_images" [label="{restaurant_images|id PK\lrestaurant_id FK\limage_url\limage_type\l}"];
  "restaurant_opening_hours" [label="{restaurant_opening_hours|id PK\lrestaurant_id FK\lday_of_week\lopen_time\lclose_time\l}"];
  "restaurant_special_closures" [label="{restaurant_special_closures|id PK\lrestaurant_id FK\lclosure_date\l}"];
  "restaurant_translations" [label="{restaurant_translations|id PK\lrestaurant_id FK\llanguage_id FK\l}"];
  "menu_uploads" [label="{menu_uploads|id PK\lrestaurant_id FK\lfile_url\lstatus\l}"];
  "menus" [label="{menus|id PK\lrestaurant_id FK\lname\lis_active\l}"];
  "menu_categories" [label="{menu_categories|id PK\lrestaurant_id FK\lname\l}"];
  "dishes" [label="{dishes|id PK\lrestaurant_id FK\lmenu_id FK\lcategory_id FK\lprice_vnd\l}"];
  "dish_images" [label="{dish_images|id PK\ldish_id FK\limage_url\l}"];
  "dish_translations" [label="{dish_translations|id PK\ldish_id FK\llanguage_id FK\l}"];
  "allergens" [label="{allergens|id PK\lname\l}"];
  "dish_allergens" [label="{dish_allergens|dish_id PK/FK\lallergen_id PK/FK\l}"];
  "dietary_tags" [label="{dietary_tags|id PK\lcode UK\lname\l}"];
  "dish_dietary_tags" [label="{dish_dietary_tags|dish_id PK/FK\ldietary_tag_id PK/FK\l}"];
  "audio_files" [label="{audio_files|id PK\ltarget_type\ltarget_id\llanguage_id FK\l}"];
  "favorites" [label="{favorites|id PK\luser_id FK\ltarget_type\ltarget_id\l}"];
  "carts" [label="{carts|id PK\luser_id FK\lrestaurant_id FK\lstatus\l}"];
  "cart_items" [label="{cart_items|id PK\lcart_id FK\ldish_id FK\lquantity\l}"];
  "orders" [label="{orders|id PK\lrestaurant_id FK\luser_id FK\lorder_code UK\ltotal_amount\l}"];
  "order_items" [label="{order_items|id PK\lorder_id FK\ldish_id FK\lquantity\l}"];
  "payment_methods" [label="{payment_methods|id PK\lcode UK\lname\l}"];
  "payments" [label="{payments|id PK\lorder_id FK\lpayment_method_id FK\lamount\lstatus\l}"];
  "restaurant_reviews" [label="{restaurant_reviews|id PK\lrestaurant_id FK\luser_id FK\lrating\l}"];
  "dish_reviews" [label="{dish_reviews|id PK\ldish_id FK\luser_id FK\lrating\l}"];
  "notifications" [label="{notifications|id PK\luser_id FK\ltitle\lis_read\l}"];
  "audit_logs" [label="{audit_logs|id PK\luser_id FK\laction\lentity_name\l}"];
  "roles" -> "users" [label="1 - n"];
  "languages" -> "user_profiles" [label="1 - n"];
  "users" -> "user_profiles" [label="1 - n"];
  "users" -> "restaurants" [label="1 - n"];
  "users" -> "favorites" [label="1 - n"];
  "users" -> "carts" [label="1 - n"];
  "users" -> "orders" [label="1 - n"];
  "users" -> "restaurant_reviews" [label="1 - n"];
  "users" -> "dish_reviews" [label="1 - n"];
  "users" -> "notifications" [label="1 - n"];
  "users" -> "audit_logs" [label="1 - n"];
  "restaurants" -> "restaurant_images" [label="1 - n"];
  "restaurants" -> "restaurant_opening_hours" [label="1 - n"];
  "restaurants" -> "restaurant_special_closures" [label="1 - n"];
  "restaurants" -> "restaurant_translations" [label="1 - n"];
  "restaurants" -> "menu_uploads" [label="1 - n"];
  "restaurants" -> "menus" [label="1 - n"];
  "restaurants" -> "menu_categories" [label="1 - n"];
  "restaurants" -> "dishes" [label="1 - n"];
  "restaurants" -> "carts" [label="1 - n"];
  "restaurants" -> "orders" [label="1 - n"];
  "restaurants" -> "restaurant_reviews" [label="1 - n"];
  "languages" -> "restaurant_translations" [label="1 - n"];
  "languages" -> "dish_translations" [label="1 - n"];
  "languages" -> "audio_files" [label="1 - n"];
  "menus" -> "dishes" [label="1 - n"];
  "menu_categories" -> "dishes" [label="1 - n"];
  "dishes" -> "dish_images" [label="1 - n"];
  "dishes" -> "dish_translations" [label="1 - n"];
  "dishes" -> "dish_allergens" [label="1 - n"];
  "allergens" -> "dish_allergens" [label="1 - n"];
  "dishes" -> "dish_dietary_tags" [label="1 - n"];
  "dietary_tags" -> "dish_dietary_tags" [label="1 - n"];
  "dishes" -> "cart_items" [label="1 - n"];
  "carts" -> "cart_items" [label="1 - n"];
  "orders" -> "order_items" [label="1 - n"];
  "dishes" -> "order_items" [label="1 - n"];
  "orders" -> "payments" [label="1 - n"];
  "payment_methods" -> "payments" [label="1 - n"];
  "dishes" -> "dish_reviews" [label="1 - n"];
}